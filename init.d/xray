#!/bin/sh /etc/rc.common
# /etc/init.d/xray — single orchestrator for this stack.
# Uses procd. Owns: ip rules, nft tables (xray_router, xray_clients), Xray.
# Does NOT own: dnsmasq (that's system-managed; we only reload it as a bonus).

# shellcheck shell=sh
# shellcheck disable=SC2034

USE_PROCD=1
START=99
STOP=10

XRAY_ROOT="/etc/xray"
XRAY_BIN="/usr/local/xray/xray"
CONF_DIR="$XRAY_ROOT/config.d"
WRAPPER="$XRAY_ROOT/bin/run-xray.sh"
RENDER_MANAGED="$XRAY_ROOT/bin/render-managed-config.sh"

log() { logger -t xray-init "$1"; printf '[xray-init] %s\n' "$1"; }

# -------- preflight --------------------------------------------------------

_preflight() {
    [ -x "$XRAY_BIN" ]    || { log "FATAL: $XRAY_BIN missing/not exec";   return 1; }
    [ -d "$CONF_DIR" ]    || { log "FATAL: $CONF_DIR missing";            return 1; }
    ls "$CONF_DIR"/*.json >/dev/null 2>&1 \
                          || { log "FATAL: no *.json in $CONF_DIR";       return 1; }
    [ -x "$WRAPPER" ]     || { log "FATAL: $WRAPPER missing";             return 1; }
    return 0
}

_render_managed() {
    [ -x "$RENDER_MANAGED" ] || { log "FATAL: $RENDER_MANAGED missing"; return 1; }
    "$RENDER_MANAGED" apply >/tmp/xray-render.log 2>&1 || {
        log "render-managed-config failed; see /tmp/xray-render.log"
        return 1
    }
    return 0
}

# -------- policy apply/flush ------------------------------------------------

_apply_policy() {
    "$XRAY_ROOT/bin/apply-iprules.sh" apply    || { log "apply-iprules failed"; return 1; }
    "$XRAY_ROOT/bin/apply-nft.sh"     apply    || { log "apply-nft failed";     return 1; }
    # Refresh sets best-effort; if it fails we still leave rules in place.
    "$XRAY_ROOT/bin/update-sets.sh"            || log "update-sets returned non-zero (continuing)"
    return 0
}

_flush_policy() {
    "$XRAY_ROOT/bin/apply-nft.sh"     flush    || log "apply-nft flush failed"
    "$XRAY_ROOT/bin/apply-iprules.sh" flush    || log "apply-iprules flush failed"
}

# -------- procd ------------------------------------------------------------

start_service() {
    _render_managed || exit 1
    _preflight || exit 1

    # xray -test before putting anything in nft — fail fast if config broken.
    if ! "$XRAY_BIN" -test -confdir "$CONF_DIR" >/tmp/xray-test.log 2>&1; then
        log "xray -test failed; not starting. See /tmp/xray-test.log"
        return 1
    fi

    _apply_policy || { _flush_policy; return 1; }

    procd_open_instance xray
    procd_set_param command "$WRAPPER"
    procd_set_param respawn ${respawn_threshold:-3600} ${respawn_timeout:-5} ${respawn_retry:-5}
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_set_param limits nofile=65535
    procd_set_param file \
        "$CONF_DIR/00-base.json" \
        "$CONF_DIR/10-inbounds.json" \
        "$CONF_DIR/20-outbounds.json" \
        "$CONF_DIR/50-routing.json"
    procd_close_instance

    log "started"
}

stop_service() {
    _flush_policy
    log "stopped"
}

reload_service() {
    # Full validate-then-swap reload. Cheaper than a stop/start.
    _render_managed || return 1
    _preflight || return 1
    if ! "$XRAY_BIN" -test -confdir "$CONF_DIR" >/tmp/xray-test.log 2>&1; then
        log "xray -test failed during reload; keeping old state"
        return 1
    fi
    _apply_policy || { log "reload: policy reapply failed"; return 1; }
    procd_send_signal xray
    log "reloaded"
}

service_triggers() {
    procd_add_reload_trigger "xray"
}
